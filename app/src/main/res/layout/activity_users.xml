<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg" android:padding="12dp">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="10dp">
    <Button android:id="@+id/btnFetchUsers" android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="44dp" android:text="Fetch Users"
        android:backgroundTint="@color/cyan" android:textColor="@color/black" android:layout_marginEnd="6dp"/>
    <Button android:id="@+id/btnClearAll" android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="44dp" android:text="Clear All"
        android:backgroundTint="@color/red" android:textColor="@color/white"/>
  </LinearLayout>
  <TextView android:id="@+id/tvEmpty" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:text="Tap Fetch Users to load enrolled users"
      android:textColor="@color/muted" android:textSize="12sp" android:gravity="center" android:padding="24dp"/>
  <ListView android:id="@+id/listUsers" android:layout_width="match_parent"
      android:layout_height="match_parent" android:visibility="gone"
      android:divider="@color/border" android:dividerHeight="1dp"/>
</LinearLayout>
