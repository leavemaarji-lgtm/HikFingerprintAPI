<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg"
    android:padding="16dp" android:gravity="center_horizontal">
  <TextView android:text="REMOTE DOOR CONTROL" android:textColor="@color/cyan"
      android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp" android:gravity="center"/>
  <TextView android:text="Commands execute immediately on device"
      android:textColor="@color/muted" android:textSize="11sp"
      android:gravity="center" android:layout_marginBottom="24dp"/>
  <Button android:id="@+id/btnUnlock" android:layout_width="match_parent"
      android:layout_height="80dp" android:text="UNLOCK DOOR"
      android:textSize="18sp" android:textStyle="bold"
      android:backgroundTint="@color/green" android:textColor="@color/black"
      android:layout_marginBottom="12dp"/>
  <Button android:id="@+id/btnLock" android:layout_width="match_parent"
      android:layout_height="80dp" android:text="LOCK DOOR"
      android:textSize="18sp" android:textStyle="bold"
      android:backgroundTint="@color/red" android:textColor="@color/white"
      android:layout_marginBottom="20dp"/>
  <Button android:id="@+id/btnStatus" android:layout_width="match_parent"
      android:layout_height="48dp" android:text="Read Door Status"
      android:backgroundTint="@color/surface" android:textColor="@color/cyan"
      android:layout_marginBottom="12dp"/>
  <TextView android:id="@+id/tvStatus" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:background="@color/card"
      android:textColor="@color/muted" android:textSize="11sp" android:padding="12dp"
      android:text="Status will appear here" android:fontFamily="monospace"/>
</LinearLayout>
